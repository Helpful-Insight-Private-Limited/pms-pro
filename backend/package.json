{
  "name": "@pms/backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx src/server.ts",
    "dev:watch": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "postbuild": "node scripts/copy-generated-client.mjs",
    "start": "node dist/src/server.js",
    "worker": "tsx src/worker.ts",
    "worker:start": "node dist/src/worker.js",
    "jobs:run": "tsx src/worker.ts --once",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "tsx prisma/seed.ts",
    "user:reset-password": "node scripts/reset-user-password.mjs"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "latest",
    "@types/nodemailer": "^8.0.1",
    "cookie-parser": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "express-rate-limit": "latest",
    "helmet": "latest",
    "jose": "latest",
    "mariadb": "^3.5.3",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "web-push": "^3.6.7",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/cookie-parser": "latest",
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/multer": "^2.2.0",
    "@types/node": "latest",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/web-push": "^3.6.4",
    "prisma": "latest",
    "tsx": "latest",
    "typescript": "latest"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
